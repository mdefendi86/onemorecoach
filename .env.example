# =============================================
# One More Coach — environment variables
#
# Copy this file to .env.local for local development.
# Set production values in Vercel → Project → Settings → Environment Variables.
# .env.local is git-ignored — never commit secrets.
#
# See REBUILD_PLAN.md §11 (analytics) and §9 (forms) for context.
# =============================================

# Google Analytics 4 — Measurement ID.
# If unset, no gtag script ships and no events fire. Site otherwise works normally.
# Wired in Phase 5.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Resend API key — required for the application form server action.
# If unset, the form returns a clear 503 error (graceful degradation per §2 principle 4).
# Wired in Phase 3.
RESEND_API_KEY=

# Application form: destination + sender addresses.
# Defaults (set in code) — CONTACT_TO_EMAIL defaults to business.email,
# CONTACT_FROM_EMAIL defaults to 'no-reply@onemorecoach.com'.
# Override here only if a dedicated alias is preferred.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
